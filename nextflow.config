manifest {
  name            = 'ericales-wgd-nextflow'
  author          = 'Brianna Banting'
  homePage        = '.'
  mainScript      = 'main.nf'
  nextflowVersion = '>=23.10.0'
}

params {
  config_for_r = 'config.yaml'

  sif_paths = [
    genespace: '',
    macse: '',
    iqtree: '',
    alerax: ''
  ]
}

process {
  shell = ['/bin/bash', '-euo', 'pipefail']
  errorStrategy = 'terminate'
  maxRetries = 1
}

trace {
  enabled = true
  file = 'trace.txt'
  overwrite = true
}

timeline {
  enabled = true
  file = 'timeline.html'
  overwrite = true
}

report {
  enabled = true
  file = 'report.html'
  overwrite = true
}

profiles {

  docker {
    docker.enabled = true
    singularity.enabled = false

    process {
      executor = 'local'

      withName: PRIMARY_TRANSCRIPT {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = params.containers.genespace
      }

      withName: FINALIZE_REPO_IDS {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = params.containers.genespace
      }

      withName: STAGE_GENOMEREPO {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = params.containers.genespace
      }

      withName: PARSE_ANNOTATIONS_BY_SOURCE {
        cpus = 4
        memory = '16 GB'
        time = '8h'
        container = params.containers.genespace
      }

      withName: VALIDATE_PARSE_OUTPUTS {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = params.containers.genespace
      }

      withName: ORTHOFINDER_OR_SKIP {
        cpus = 16
        memory = '128 GB'
        time = '24h'
        container = params.containers.genespace
      }

      withName: RUN_GENESPACE {
        cpus = 16
        memory = '128 GB'
        time = '24h'
        container = params.containers.genespace
      }

      withName: PANGENES_PASS_FILTER {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = params.containers.genespace
      }

      withName: WRITE_OG_FASTAS {
        cpus = 2
        memory = '8 GB'
        time = '6h'
        container = params.containers.genespace
      }

      withName: MACSE_ALIGN_OG {
        cpus = 1
        memory = '4 GB'
        time = '6h'
        container = params.containers.macse
        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = '-1'
      }

      withName: MACSE_REPORT {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = params.containers.macse
      }

      withName: IQTREE_OG {
        cpus = 4
        memory = '8 GB'
        time = '8h'
        container = params.containers.iqtree
      }

      withName: IQTREE_REPORT {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = params.containers.iqtree
      }

      withName: WRITE_ALERAX_MAPPING {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = params.containers.alerax
      }

      withName: WRITE_ALERAX_FAMILIES {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = params.containers.alerax
      }

      withName: RUN_ALERAX {
        cpus = 32
        memory = '256 GB'
        time = '48h'
        container = params.containers.alerax
      }
    }
  }

  eddie {
    docker.enabled = false
    singularity.enabled = false
    apptainer.enabled = true

    apptainer {
      autoMounts = true
    }

    process {
      executor = 'sge'
      clusterOptions = '-cwd -V'
      penv = 'sharedmem'

      withName: PRIMARY_TRANSCRIPT {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: FINALIZE_REPO_IDS {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: STAGE_GENOMEREPO {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: PARSE_ANNOTATIONS_BY_SOURCE {
        cpus = 4
        memory = '16 GB'
        time = '8h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: VALIDATE_PARSE_OUTPUTS {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: ORTHOFINDER_OR_SKIP {
        cpus = 16
        memory = '64 GB'
        time = '4h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: RUN_GENESPACE {
        cpus = 16
        memory = '128 GB'
        time = '24h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: PANGENES_PASS_FILTER {
        cpus = 1
        memory = '4 GB'
        time = '2h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: WRITE_OG_FASTAS {
        cpus = 2
        memory = '8 GB'
        time = '6h'
        container = "file://${params.sif_paths.genespace}"
      }

      withName: MACSE_ALIGN_OG {
        cpus = 1
        memory = '4 GB'
        time = '6h'
        container = "file://${params.sif_paths.macse}"
        errorStrategy = 'retry'
        maxRetries = 2
        maxErrors = '-1'
      }

      withName: MACSE_REPORT {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = "file://${params.sif_paths.macse}"
      }

      withName: IQTREE_OG {
        cpus = 4
        memory = '8 GB'
        time = '8h'
        container = "file://${params.sif_paths.iqtree}"
      }

      withName: IQTREE_REPORT {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = "file://${params.sif_paths.iqtree}"
      }

      withName: WRITE_ALERAX_MAPPING {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = "file://${params.sif_paths.alerax}"
      }

      withName: WRITE_ALERAX_FAMILIES {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        container = "file://${params.sif_paths.alerax}"
      }

      withName: RUN_ALERAX {
        cpus = 32
        memory = '256 GB'
        time = '48h'
        container = "file://${params.sif_paths.alerax}"
      }
    }
  }
}
